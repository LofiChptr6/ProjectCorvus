# Copy to .env and fill in real values. NEVER commit .env.
# .gitignore covers .env, .env.local, and any .env.* file (except this example).

# ── Telegram (approval workflow + concierge) ──────────────────────────────────
# Create a bot via @BotFather, copy the token below.
TELEGRAM_BOT_TOKEN=123456789:ABC...

# Auto-detected from the first user who messages the bot. Cached to
# data/telegram_chat_id.txt. Pin a specific chat to bypass auto-detect:
# TELEGRAM_CHAT_ID=987654321

# ── Local LLM (vLLM, OpenAI-compatible) ───────────────────────────────────────
# vLLM serves an OpenAI-compatible API on this URL. Concierge talks here directly;
# scheduled skills go through the litellm proxy (see LOCAL_PROXY_URL below).
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_MODEL=Qwen/Qwen3-32B-FP8

# ── Observability proxy + dashboard (obs/) ───────────────────────────────────
# The launcher routes `claude` CLI through the proxy at LLM_PROXY_URL so every
# /v1/messages exchange lands in Postgres audit_log + tool_calls. If the proxy
# is unreachable, the launcher falls back to LOCAL_LLM_FALLBACK_URL.
LLM_PROXY_URL=http://localhost:8001
LOCAL_LLM_FALLBACK_URL=http://localhost:8000
OBS_DASHBOARD_URL=http://localhost:8501

# Concierge token cap per UTC day (was a USD cap under Sonnet; local inference
# is free, but a runaway tool-loop can still burn GPU time).
CONCIERGE_DAILY_TOKEN_CAP=2000000

# ── Anthropic (legacy — only needed to roll back to main) ─────────────────────
# Kept so `git checkout main && systemctl --user start trading-*` works without
# re-issuing keys. On the local-llm branch, concierge does not read this.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Massive.com (market data — Polygon-compatible REST) ───────────────────────
# Used by data/massive_client.py for quotes/bars/news.
# Get your key at https://massive.com/dashboard
MASSIVE_API_KEY=

# ── PostgreSQL (optional overrides; defaults read from config.yaml) ───────────
# Override any of these to take precedence over config.yaml:
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=trading
# PG_USER=trading
# PG_PASSWORD=

# ── IBKR client id (per-skill assignment lives in scripts/run_scheduled_skill.sh) ──
# IBKR_CLIENT_ID=1
