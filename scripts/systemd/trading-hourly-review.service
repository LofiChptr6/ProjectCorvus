Documentation=file:///home/tianyizhang/opus%20trading/scripts/run_hourly_orchestrator.sh
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/tianyizhang/opus trading
Environment=PATH=/home/tianyizhang/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/bin/bash "/home/tianyizhang/opus trading/scripts/run_hourly_orchestrator.sh"
